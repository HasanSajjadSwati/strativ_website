# Strativ — environment variables
#
# On Coolify you do NOT need this file: Coolify auto-generates every SERVICE_*
# value and injects it. This file is only for running `docker compose up`
# locally — copy it to `.env` and fill in the blanks.
#
#   cp .env.example .env
#   docker compose up --build

# Public URL of the site (Coolify sets this automatically from the domain).
SERVICE_FQDN_WORDPRESS=http://localhost:8080

# Database
MYSQL_DATABASE=strativ
SERVICE_USER_MYSQL=strativ
SERVICE_PASSWORD_MYSQL=change-me-db-password
SERVICE_PASSWORD_MYSQLROOT=change-me-root-password

# First-boot WordPress admin account
WP_TITLE=Strativ — Software That Ships
WP_ADMIN_USER=admin
SERVICE_PASSWORD_WPADMIN=change-me-admin-password
WP_ADMIN_EMAIL=admin@example.com
