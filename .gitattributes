# Normalize line endings. Shell scripts MUST stay LF or they break in Linux
# containers (a CRLF shebang yields "bad interpreter").
* text=auto eol=lf
*.sh   text eol=lf
*.php  text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.bat  text eol=crlf
*.ps1  text eol=crlf

# Treat vendored libraries and binaries as-is.
*.min.js   -text
*.png      binary
*.jpg      binary
*.phar     binary
